{
    "configurations": [
        {
            "name": "Contiki",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/../../core/**",
                "${workspaceFolder}/../../cpu/**",
                "${workspaceFolder}/../../platform/**"
            ],
            "defines": [
                "__CONTIKI__",
                "CONTIKI_TARGET_NATIVE"
            ],
            "compilerPath": "",
            "cStandard": "c99",
            "cppStandard": "c++17",
            "intelliSenseMode": "linux-gcc-x86",
            "browse": {
                "path": [
                    "${workspaceFolder}/**"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ],
    "version": 4
}
